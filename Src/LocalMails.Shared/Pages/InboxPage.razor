@code {
    private string _mailTab = "all";
    private bool _mobileShowDetail;

    protected override async Task OnInitializedAsync()
    {
        MailState.OnChanged += OnStateChanged;
        await MailState.LoadMessagesAsync();
        
        // Auto-select first message if any
        if (MailState.Messages.Any() && MailState.SelectedMessage == null)
        {
            MailState.SelectedMessage = MailState.Messages.First();
        }
    }

    private async void OnStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private List<EmailMessage> FilteredMessages => MailState.Messages
        .Where(m => string.IsNullOrEmpty(MailState.SearchTerm) || 
                   m.Subject.Contains(MailState.SearchTerm, StringComparison.OrdinalIgnoreCase) ||
                   m.From.Contains(MailState.SearchTerm, StringComparison.OrdinalIgnoreCase) ||
                   m.BodyText.Contains(MailState.SearchTerm, StringComparison.OrdinalIgnoreCase))
        .ToList();

    private void SelectMessage(EmailMessage message)
    {
        MailState.SelectedMessage = message;
        _mobileShowDetail = true;
    }

    private async Task ClearInbox()
    {
        await MailState.ClearInboxAsync();
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "??";
        var parts = name.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..Math.Min(2, parts[0].Length)].ToUpper();
        return (parts[0][0].ToString() + parts[1][0].ToString()).ToUpper();
    }

    private string FormatDate(DateTime date)
    {
        var local = date.ToLocalTime();
        if (local.Date == DateTime.Today) return local.ToString("t");
        if (local.Date == DateTime.Today.AddDays(-1)) return "Yesterday";
        return local.ToString("MMM d");
    }

    public void Dispose()
    {
        MailState.OnChanged -= OnStateChanged;
    }
}
