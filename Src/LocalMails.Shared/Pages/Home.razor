@page "/"

@using LocalMails.Server.Models
@using LocalMails.Server.Services
@using LocalMails.Server.Data
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.EntityFrameworkCore
@implements IDisposable

@inject IServiceScopeFactory ScopeFactory
@inject IEmailNotifier Notifier

<PageTitle>LocalMails Inbox</PageTitle>

<div>
    <div>
        <button class="fluent-button" @onclick="ClearInbox">
            Clear Inbox
        </button>
    </div>

    @if (selectedMessage != null)
    {
        <div style="display:flex; flex-direction:column; height: 100%;">
            <div style="display:flex; justify-content:space-between; align-items:center; border-bottom: 1px solid #ddd; padding-bottom: 15px; margin-bottom: 15px;">
                <div>
                    <h2>@selectedMessage.Subject</h2>
                    <div style="color:var(--neutral-foreground-hint);">
                        <strong>From:</strong> @selectedMessage.From <br/>
                        <strong>To:</strong> @selectedMessage.To <br/>
                        <strong>Received:</strong> @selectedMessage.ReceivedDate.ToLocalTime().ToString("g")
                    </div>
                </div>
                <button @onclick="() => selectedMessage = null">
                    Back to Inbox
                </button>
            </div>
            
            <div>
                <div>
                    HTML Body
                    <div style="background:#fff; color:#000; padding:15px; border-radius:8px; height: 50vh; overflow-y:auto; border: 1px solid #ccc;">
                        @((MarkupString)selectedMessage.BodyHtml)
                    </div>
                </div>
                <div>
                    Plain Text
                    <div style="background:#f9f9f9; padding:15px; border-radius:8px; white-space:pre-wrap; height: 50vh; overflow-y:auto; font-family: monospace;">
                        @selectedMessage.BodyText
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        @if (messages == null)
        {
            <p><em>Loading...</em></p>
        }
        else if (!messages.Any())
        {
            <div style="text-align:center; padding: 50px; color: var(--neutral-foreground-hint);">
                <h2>Inbox is empty</h2>
                <p>Start your application and send emails to localhost:1025. They will appear here.</p>
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>From</th>
                        <th>To</th>
                        <th>Subject</th>
                        <th>Size</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var message in messages)
                    {
                        <tr @onclick="() => OnRowClicked(message)">
                            <td>@message.ReceivedDate.ToLocalTime().ToString("g")</td>
                            <td>@message.From</td>
                            <td>@message.To</td>
                            <td>@message.Subject</td>
                            <td>@FormatBytes(message.Size)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
</div>

@code {
    private List<EmailMessage>? messages;
    private EmailMessage? selectedMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadMessagesAsync();

        Notifier.OnEmailReceived += HandleNewEmail;
        Notifier.OnEmailsCleared += HandleEmailsCleared;
    }

    private async Task LoadMessagesAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        messages = await db.Messages.OrderByDescending(m => m.ReceivedDate).Take(100).ToListAsync();
    }

    private async void HandleNewEmail(EmailMessage msg)
    {
        await InvokeAsync(async () =>
        {
            if (messages != null)
            {
                messages.Insert(0, msg);
                StateHasChanged();
            }
        });
    }

    private async void HandleEmailsCleared()
    {
        await InvokeAsync(() =>
        {
            messages?.Clear();
            selectedMessage = null;
            StateHasChanged();
        });
    }

    private async Task ClearInbox()
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        db.Messages.RemoveRange(db.Messages);
        await db.SaveChangesAsync();

        messages?.Clear();
        selectedMessage = null;
    }

    private void OnRowClicked(EmailMessage message)
    {
        selectedMessage = message;
    }

    private string FormatBytes(long bytes)
    {
        string[] suffix = { "B", "KB", "MB", "GB" };
        int i;
        double dblSByte = bytes;
        for (i = 0; i < suffix.Length && bytes >= 1024; i++, bytes /= 1024)
        {
            dblSByte = bytes / 1024.0;
        }

        return String.Format("{0:0.##} {1}", dblSByte, suffix[i]);
    }

    public void Dispose()
    {
        Notifier.OnEmailReceived -= HandleNewEmail;
        Notifier.OnEmailsCleared -= HandleEmailsCleared;
    }
}
