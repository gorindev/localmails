<FluentAppBar Orientation="@Orientation.Vertical" Style="@(" background-color: var(--neutral-layer-2);")">
    <FluentAppBarItem Href="/"
                        Match="NavLinkMatch.All"
                        IconRest="MailInbox()"
                        IconActive="MailInbox(active: true)"
                        Text="Home" />
    <FluentAppBarItem Href="/settings"
                        IconRest="SettingsIcon()"
                        IconActive="SettingsIcon(active: true)"
                        Text="Settings" />
</FluentAppBar>

@code {
    private static Icon MailInbox(bool active = false) =>
        active ? new Icons.Filled.Size24.MailInbox()
               : new Icons.Regular.Size24.MailInbox();

    private static Icon SettingsIcon(bool active = false) =>
        active ? new Icons.Filled.Size24.Settings()
               : new Icons.Regular.Size24.Settings();
}
