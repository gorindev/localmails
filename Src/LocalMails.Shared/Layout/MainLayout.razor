@inherits LayoutComponentBase
@using LocalMails.Shared.Services
@using BlazorBlueprint
@using BlazorBlueprint.Components
@using BlazorBlueprint.Primitives
@using BlazorBlueprint.Icons.Lucide.Components
@using BlazorBlueprint.Icons.Lucide.Data
@inject MailState MailState

<div class="flex flex-col h-dvh bg-background overflow-hidden">
    @Body
</div>

<div id="blazor-error-ui" style="display:none; position:fixed; bottom:0; width:100%; background: lightyellow; padding: 10px; border-top: 1px solid red; z-index: 1000;">
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<BbPortalHost />
<BbToastProvider />
<BbDialogProvider />

@code {
    private void OnSearchChanged(string term)
    {
        MailState.SearchTerm = term;
    }
}
